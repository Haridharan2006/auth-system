{
  "version": 3,
  "extra_config": {
    "github.com/devopsfaith/krakend-cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE"],
      "allow_headers": ["Content-Type", "Authorization"]
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/login",
      "method": "POST",
      "backend": [
        {
          "url_pattern": "/auth/login",
          "host": ["http://nginx"]
        }
      ]
    }
  ]
}